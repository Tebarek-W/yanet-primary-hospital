generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id            String   @id
  content       Json
  lastUpdatedBy String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Branch {
  slug               String   @id
  name               String
  nameAm             String
  city               String
  cityAm             String
  address            String
  addressAm          String
  phone              String
  email              String
  mapEmbedUrl        String   @db.Text
  workingHours       Json
  serviceSlugs       Json
  doctorIds          Json
  image              String
  featuredServices   Json
  featuredServicesAm Json
  theme              Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}


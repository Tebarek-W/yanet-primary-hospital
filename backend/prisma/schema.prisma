generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id            String   @id
  content       Json
  lastUpdatedBy String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Branch {
  slug               String   @id
  name               String
  nameAm             String
  city               String
  cityAm             String
  address            String
  addressAm          String
  phone              String
  email              String
  mapEmbedUrl        String   @db.Text
  workingHours       Json
  serviceSlugs       Json
  doctorIds          Json
  image              String
  featuredServices   Json
  featuredServicesAm Json
  theme              Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Doctor {
  id            Int      @id @default(autoincrement())
  name          String
  nameAm        String   @default("")
  roleKey       String   @default("doctor_team.roles.general")
  specialty     String
  image         String   @db.Text
  desc          String   @db.Text
  descAm        String   @db.Text
  email         String   @unique
  phone         String   @default("")
  password      String
  location      String   @default("Addis Ababa, Ethiopia")
  education     Json
  educationAm   Json
  experience    Json
  experienceAm  Json
  skills        Json
  skillsAm      Json
  biography     String   @db.Text
  biographyAm   String   @db.Text
  branchSlugs   Json
  isActive      Boolean  @default(true)
  blogs         Blog[]
  messageChannels MessageChannel[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Blog {
  id         Int      @id @default(autoincrement())
  title      String
  titleAm    String
  category   String
  categoryAm String
  content    String   @db.Text
  contentAm  String   @db.Text
  image      String   @db.Text
  date       String
  authorId   Int
  doctor     Doctor   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MessageChannel {
  id          Int            @id @default(autoincrement())
  patientName String
  age         Int
  avatar      String       @db.Text
  symptoms    String
  unread      Boolean        @default(false)
  doctorId    Int
  doctor      Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  history     ChatMessage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ChatMessage {
  id        Int            @id @default(autoincrement())
  channelId Int
  channel   MessageChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender    String         // 'patient' or 'doctor'
  text      String         @db.Text
  time      String
  createdAt DateTime       @default(now())
}
